    private fun formatTeamStats(jsonResponse: String): String {
        return try {
            val json = JSONObject(jsonResponse)
            val weather = if (json.has("weather")) json.getJSONObject("weather") else null
            val weatherIcon = weather?.getString("icon") ?: ""
            val weatherTemp = weather?.getInt("temperature") ?: 0
            val weatherConditions = weather?.getString("conditions") ?: ""
            
            val sb = StringBuilder()
            sb.append("📊 TEAM STATS\n")
            sb.append("════════════════\n")
            sb.append("Record: ${json.optString("record", "N/A")}\n")
            sb.append("PF: ${json.optDouble("points_for", 0.0)} | PA: ${json.optDouble("points_against", 0.0)}\n")
            sb.append("Streak: ${json.optInt("streak", 0)}\n")
            sb.append("Next: ${json.optString("next_game", "N/A")}\n")
            
            if (weather != null) {
                sb.append("\n☁️ CURRENT WEATHER\n")
                sb.append("$weatherIcon ${weatherTemp}°F, $weatherConditions\n")
            }
            
            sb.toString()
        } catch (e: Exception) {
            "Error parsing team stats"
        }
    }

    private fun formatPlayerStats(jsonResponse: String): String {
        return try {
            val json = JSONObject(jsonResponse)
            
            val sb = StringBuilder()
            sb.append("👤 PLAYER STATS\n")
            sb.append("════════════════\n")
            sb.append("${json.optString("name", "")} (${json.optString("position", "")})\n")
            sb.append("Team: ${json.optString("team", "N/A")}\n")
            sb.append("TD: ${json.optInt("touchdowns", 0)}\n")
            
            if (json.has("passing_yards")) {
                sb.append("Pass Yds: ${json.optInt("passing_yards", 0)}\n")
                sb.append("Comp%: ${json.optDouble("completion_pct", 0.0)}%\n")
            }
            if (json.has("rushing_yards")) {
                sb.append("Rush Yds: ${json.optInt("rushing_yards", 0)}\n")
            }
            if (json.has("receiving_yards")) {
                sb.append("Rec Yds: ${json.optInt("receiving_yards", 0)}\n")
            }
            
            sb.append("\n🏥 Status: ${json.optString("injury_status", "Healthy")}\n")
            
            sb.toString()
        } catch (e: Exception) {
            "Error parsing player stats"
        }
    }

    private fun formatWeather(jsonResponse: String): String {
        return try {
            val json = JSONObject(jsonResponse)
            val weather = json.getJSONObject("weather")
            
            """
                ☁️ WEATHER
                ════════════════
                📍 ${json.getString("stadium")}
                🏙️ ${json.getString("city")}
                
                🌡️ Temp: ${weather.getInt("temperature")}°F
                ☁️ Conditions: ${weather.getString("conditions")}
                💨 Wind: ${weather.getInt("wind_speed")} mph
                ☔ Precip: ${weather.getInt("precipitation")}%
                
                ℹ️ IMPACT:
                ${json.getString("impact")}
            """.trimIndent()
        } catch (e: Exception) {
            "Error parsing weather"
        }
    }

    private fun formatInjuries(jsonResponse: String): String {
        return try {
            val json = JSONObject(jsonResponse)
            val injuries = json.getJSONArray("injuries")
            
            val sb = StringBuilder()
            sb.append("🏥 INJURY REPORT\n")
            sb.append("════════════════\n")
            sb.append("Total: ${json.getInt("total_injuries")}\n\n")
            
            for (i in 0 until injuries.length()) {
                val injury = injuries.getJSONObject(i)
                val statusEmoji = when (injury.getString("status")) {
                    "Out" -> "❌"
                    "Questionable" -> "⚠️"
                    else -> "✅"
                }
                sb.append("$statusEmoji ${injury.getString("player")} (${injury.getString("position")})\n")
                sb.append("   ${injury.getString("status")} - ${injury.getString("injury")}\n\n")
            }
            
            sb.toString()
        } catch (e: Exception) {
            "Error parsing injuries"
        }
    }

    private fun formatNews(jsonResponse: String): String {
        return try {
            val json = JSONObject(jsonResponse)
            val newsArray = json.getJSONArray("news")
            
            val sb = StringBuilder()
            sb.append("📰 LATEST NEWS\n")
            sb.append("════════════════\n")
            sb.append("${json.getString("entity")}\n")
            sb.append("🕐 ${json.getString("timestamp")}\n\n")
            
            for (i in 0 until newsArray.length()) {
                val news = newsArray.getJSONObject(i)
                sb.append("📌 ${news.getString("title")}\n")
                sb.append("   📅 ${news.getString("date")} | ${news.getString("source")}\n\n")
            }
            
            sb.toString()
        } catch (e: Exception) {
            "Error parsing news"
        }
    }

    private fun formatWinLoss(jsonResponse: String): String {
        return try {
            val json = JSONObject(jsonResponse)
            val last5 = json.getJSONArray("last_5")
            
            val streakEmoji = if (json.getString("streak_type") == "winning") "🔥" else "📉"
            
            val sb = StringBuilder()
            sb.append("📊 SEASON RECORD\n")
            sb.append("════════════════\n")
            sb.append("${json.getString("team")}\n\n")
            sb.append("Record: ${json.getInt("wins")}-${json.getInt("losses")}\n")
            sb.append("Win %: ${json.getDouble("win_percentage")}%\n")
            sb.append("$streakEmoji Streak: ${json.getInt("streak")} ${json.getString("streak_type")}\n\n")
            
            sb.append("📈 LAST 5:\n   ")
            for (i in 0 until last5.length()) {
                when (last5.getString(i)) {
                    "W" -> sb.append("✅ ")
                    else -> sb.append("❌ ")
                }
            }
            
            sb.toString()
        } catch (e: Exception) {
            "Error parsing win/loss"
        }
    }

    private fun showTeamUpdateForm() {
        currentUpdateMode = "team"
        formTitle.text = "UPDATE TEAM"
        editField1.hint = "Wins"
        editField2.hint = "Losses"
        editField3.hint = "PPG"
        updateFormCard.visibility = View.VISIBLE
    }

    private fun showPlayerUpdateForm() {
        currentUpdateMode = "player"
        formTitle.text = "UPDATE PLAYER"
        editField1.hint = "Touchdowns"
        editField2.hint = "Yards"
        editField3.hint = "Comp%"
        updateFormCard.visibility = View.VISIBLE
    }

    private fun hideUpdateForm() {
        updateFormCard.visibility = View.GONE
    }

    private fun submitUpdate() {
        when (currentUpdateMode) {
            "team" -> updateTeamStats()
            "player" -> updatePlayerStats()
        }
    }

    private fun updateTeamStats() {
        val team = teamSpinner.selectedItem?.toString() ?: return
        val wins = editField1.text.toString()
        val losses = editField2.text.toString()
        val ppg = editField3.text.toString()

        if (wins.isEmpty() || losses.isEmpty() || ppg.isEmpty()) {
            Toast.makeText(this, "Fill all fields", Toast.LENGTH_SHORT).show()
            return
        }

        showLoading(true)
        resultText.text = "Updating..."

        coroutineScope.launch {
            val result = withContext(Dispatchers.IO) {
                try {
                    val url = URL("$BASE_URL/update_team")
                    val connection = url.openConnection() as HttpURLConnection
                    connection.requestMethod = "POST"
                    connection.doOutput = true
                    connection.setRequestProperty("Content-Type", "application/json")

                    val json = JSONObject().apply {
                        put("team", team)
                        put("wins", wins.toInt())
                        put("losses", losses.toInt())
                        put("ppg", ppg.toDouble())
                    }

                    OutputStreamWriter(connection.outputStream).use {
                        it.write(json.toString())
                        it.flush()
                    }

                    if (connection.responseCode == HttpURLConnection.HTTP_OK) {
                        "✅ Team updated!"
                    } else {
                        "❌ Update failed"
                    }
                } catch (e: Exception) {
                    "❌ Error: ${e.message}"
                }
            }
            showLoading(false)
            hideUpdateForm()
            resultText.text = result
        }
    }

    private fun updatePlayerStats() {
        val player = playerSpinner.selectedItem?.toString() ?: return
        val tds = editField1.text.toString()
        val yards = editField2.text.toString()
        val comp = editField3.text.toString()

        if (tds.isEmpty() || yards.isEmpty() || comp.isEmpty()) {
            Toast.makeText(this, "Fill all fields", Toast.LENGTH_SHORT).show()
            return
        }

        showLoading(true)
        resultText.text = "Updating..."

        coroutineScope.launch {
            val result = withContext(Dispatchers.IO) {
                try {
                    val url = URL("$BASE_URL/update_player")
                    val connection = url.openConnection() as HttpURLConnection
                    connection.requestMethod = "POST"
                    connection.doOutput = true
                    connection.setRequestProperty("Content-Type", "application/json")

                    val json = JSONObject().apply {
                        put("name", player)
                        put("touchdowns", tds.toInt())
                        put("yards", yards.toInt())
                        put("completion_pct", comp.toDouble())
                    }

                    OutputStreamWriter(connection.outputStream).use {
                        it.write(json.toString())
                        it.flush()
                    }

                    if (connection.responseCode == HttpURLConnection.HTTP_OK) {
                        "✅ Player updated!"
                    } else {
                        "❌ Update failed"
                    }
                } catch (e: Exception) {
                    "❌ Error: ${e.message}"
                }
            }
            showLoading(false)
            hideUpdateForm()
            resultText.text = result
        }
    }

    private fun refreshAll() {
        testConnection()
    }

    private fun clearResults() {
        resultText.text = "Ready"
        statusText.text = "Status: Unknown"
    }

    private fun showHelp() {
        resultText.text = """
            📱 HELP
            ════════
            TEST: Check connection
            STATS: Team/player data
            WEATHER: Game day forecast
            INJURIES: Player status
            NEWS: Latest updates
            RECORD: Win/loss tracker
            UPDATE: Modify stats
        """.trimIndent()
    }

    private fun showLoading(show: Boolean) {
        loadingIndicator.visibility = if (show) View.VISIBLE else View.GONE
        testButton.isEnabled = !show
        loadStatsButton.isEnabled = !show
        loadPlayerButton.isEnabled = !show
        weatherButton.isEnabled = !show
        injuriesButton.isEnabled = !show
        newsButton.isEnabled = !show
        recordButton.isEnabled = !show
    }

    override fun onDestroy() {
        super.onDestroy()
        coroutineScope.cancel()
    }
}