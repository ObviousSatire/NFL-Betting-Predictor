                            response.append(line)
                        }
                        reader.close()
                        formatPlayerStats(response.toString())
                    } else {
                        "❌ HTTP Error: ${connection.responseCode}"
                    }
                } catch (e: Exception) {
                    "❌ Error: ${e.message}"
                }
            }
            showLoading(false)
            resultText.text = result
        }
    }

