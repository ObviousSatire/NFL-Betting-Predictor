    private fun loadNews() {
        val selectedTeam = teamSpinner.selectedItem?.toString() ?: return
        showLoading(true)
        resultText.text = "Loading news..."

        coroutineScope.launch {
            val result = withContext(Dispatchers.IO) {
                try {
                    val url = URL("$BASE_URL/news?entity=$selectedTeam&type=team")
