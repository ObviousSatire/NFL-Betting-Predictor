# Read, fix, and write the gitignore
$content = Get-Content .gitignore
$fixed = @()
foreach ($line in $content) {
    # Skip lines that block APK uploads
    if ($line -match '^\*\.apk$' -or $line -match '^\*\.ap_$' -or $line -match "Don't upload APK") {
        continue
    }
    $fixed += $line
}
$fixed | Set-Content .gitignore

# Verify it's gone
Select-String -Path .gitignore -Pattern "apk"

# Now add and push
git add .gitignore
git add -f NFL-Betting-Predictor.apk
git commit -m "Add APK for direct download"
git push