import requests
from flask import Flask, jsonify, request
from flask_cors import CORS
from datetime import datetime
import time

app = Flask(__name__)
CORS(app)

# Cache to avoid hitting ESPN rate limits
cache = {}
cache_timeout = 300  # 5 minutes

# ESPN API base URL
ESPN_BASE = "https://site.api.espn.com/apis/site/v2/sports/football/nfl"

# Team mapping for ESPN
TEAM_MAP = {
    "Buffalo Bills": "buf",
    "Miami Dolphins": "mia",
    "New England Patriots": "ne",
    "New York Jets": "nyj",
    "Baltimore Ravens": "bal",
    "Cincinnati Bengals": "cin",
    "Cleveland Browns": "cle",
    "Pittsburgh Steelers": "pit",
    "Houston Texans": "hou",
    "Indianapolis Colts": "ind",
    "Jacksonville Jaguars": "jax",
    "Tennessee Titans": "ten",
    "Denver Broncos": "den",
    "Kansas City Chiefs": "kc",
    "Las Vegas Raiders": "lv",
    "Los Angeles Chargers": "lac",
    "Dallas Cowboys": "dal",
    "New York Giants": "nyg",
    "Philadelphia Eagles": "phi",
    "Washington Commanders": "was",
    "Chicago Bears": "chi",
    "Detroit Lions": "det",
    "Green Bay Packers": "gb",
    "Minnesota Vikings": "min",
    "Atlanta Falcons": "atl",
    "Carolina Panthers": "car",
    "New Orleans Saints": "no",
    "Tampa Bay Buccaneers": "tb",
    "Arizona Cardinals": "ari",
    "Los Angeles Rams": "lar",
    "San Francisco 49ers": "sf",
    "Seattle Seahawks": "sea"
}

def get_cached_or_fetch(url, cache_key):
    """Cache results to avoid rate limiting"""
    if cache_key in cache:
        data, timestamp = cache[cache_key]
        if time.time() - timestamp < cache_timeout:
            return data
    
    try:
        response = requests.get(url, timeout=5)
        data = response.json()
        cache[cache_key] = (data, time.time())
        return data
    except Exception as e:
        print(f"Error fetching {url}: {e}")
        return None

@app.route('/test', methods=['GET'])
def test():
    return jsonify({"status": "ok", "message": "ESPN API Connected"})

@app.route('/team_stats', methods=['GET'])
def get_team_stats():
    team = request.args.get('team')
    
    if team not in TEAM_MAP:
        return jsonify({"error": "Team not found"}), 404
    
    team_abbr = TEAM_MAP[team]
    
    # Get team data from ESPN
    url = f"{ESPN_BASE}/teams/{team_abbr}"
    data = get_cached_or_fetch(url, f"team_{team_abbr}")
    
    if not data:
        return jsonify({"error": "Could not fetch team data"}), 500
    
    # Extract relevant stats
    team_data = data.get('team', {})
    
    # Get standings data
    standings_url = f"{ESPN_BASE}/standings"
    standings = get_cached_or_fetch(standings_url, "standings")
    
    record = "0-0"
    streak = "N/A"
    
    if standings:
        for entry in standings.get('standings', {}).get('entries', []):
            if entry.get('team', {}).get('id') == team_data.get('id'):
                stats = entry.get('stats', [])
                for stat in stats:
                    if stat.get('name') == 'wins':
                        wins = stat.get('value', 0)
                    if stat.get('name') == 'losses':
                        losses = stat.get('value', 0)
                    if stat.get('name') == 'streak':
                        streak = stat.get('displayValue', 'N/A')
                record = f"{wins}-{losses}"
    
    return jsonify({
        "team": team,
        "record": record,
        "streak": streak,
        "points_for": "N/A from ESPN",
        "points_against": "N/A from ESPN"
    })

@app.route('/player_stats', methods=['GET'])
def get_player_stats():
    name = request.args.get('name')
    
    # Search for player across all teams
    teams_url = f"{ESPN_BASE}/teams"
    teams_data = get_cached_or_fetch(teams_url, "all_teams")
    
    if not teams_data:
        return jsonify({"error": "Could not fetch teams"}), 500
    
    for team in teams_data.get('sports', [])[0].get('leagues', [])[0].get('teams', []):
        team_abbr = team['team']['abbreviation'].lower()
        roster_url = f"{ESPN_BASE}/teams/{team_abbr}"
        roster_data = get_cached_or_fetch(roster_url, f"roster_{team_abbr}")
        
        if roster_data:
            athletes = roster_data.get('team', {}).get('athletes', [])
            for athlete in athletes:
                if name.lower() in athlete.get('fullName', '').lower():
                    return jsonify({
                        "name": athlete['fullName'],
                        "position": athlete.get('position', {}).get('abbreviation', 'N/A'),
                        "team": team['team']['displayName'],
                        "jersey": athlete.get('jersey', 'N/A'),
                        "injured": False  # ESPN doesn't provide this directly
                    })
    
    return jsonify({"error": "Player not found"}), 404

@app.route('/injuries', methods=['GET'])
def get_injuries():
    team = request.args.get('team')
    
    # ESPN has an injuries endpoint
    url = f"{ESPN_BASE}/injuries"
    injuries_data = get_cached_or_fetch(url, "all_injuries")
    
    if not injuries_data:
        return jsonify({"error": "Could not fetch injuries"}), 500
    
    # Filter for specific team if requested
    all_injuries = []
    for injury in injuries_data.get('injuries', []):
        if not team or team.lower() in injury.get('team', {}).get('name', '').lower():
            all_injuries.append({
                "player": injury.get('athlete', {}).get('fullName', 'Unknown'),
                "position": injury.get('athlete', {}).get('position', {}).get('abbreviation', 'N/A'),
                "injury": injury.get('injury', {}).get('type', 'Unknown'),
                "status": injury.get('status', 'Unknown')
            })
    
    return jsonify({
        "team": team if team else "All Teams",
        "injuries": all_injuries
    })

@app.route('/news', methods=['GET'])
def get_news():
    entity = request.args.get('entity', '')
    
    # ESPN news endpoint
    url = f"{ESPN_BASE}/news"
    if entity:
        url += f"?team={TEAM_MAP.get(entity, '')}"
    
    news_data = get_cached_or_fetch(url, f"news_{entity}")
    
    if not news_data:
        return jsonify({"error": "Could not fetch news"}), 500
    
    articles = []
    for article in news_data.get('articles', [])[:10]:
        articles.append({
            "headline": article.get('headline', 'No headline'),
            "date": article.get('published', ''),
            "source": "ESPN",
            "description": article.get('description', '')
        })
    
    return jsonify({"news": articles})

@app.route('/win_loss', methods=['GET'])
def get_win_loss():
    team = request.args.get('team')
    
    if team not in TEAM_MAP:
        return jsonify({"error": "Team not found"}), 404
    
    # Get standings
    url = f"{ESPN_BASE}/standings"
    standings = get_cached_or_fetch(url, "standings")
    
    if not standings:
        return jsonify({"error": "Could not fetch standings"}), 500
    
    for entry in standings.get('standings', {}).get('entries', []):
        if entry.get('team', {}).get('name') == team:
            stats = {}
            for stat in entry.get('stats', []):
                stats[stat.get('name')] = stat.get('displayValue', 'N/A')
            
            # Get last 5 games (not directly from ESPN)
            return jsonify({
                "season_record": stats.get('vsPlayoffs', 'N/A'),
                "win_percentage": 0.0,
                "current_streak": stats.get('streak', 'N/A'),
                "last_5_games": ["W", "L", "W", "L", "W"],  # Placeholder
                "home_record": stats.get('homeRecord', 'N/A'),
                "away_record": stats.get('awayRecord', 'N/A'),
                "division_record": stats.get('divisionRecord', 'N/A')
            })
    
    return jsonify({"error": "Team not found in standings"}), 404

@app.route('/weather', methods=['GET'])
def get_weather():
    team = request.args.get('team')
    
    # Use National Weather Service API (free, no key)
    stadiums = {
        "Buffalo Bills": {"lat": 42.7738, "lon": -78.7870},
        "Kansas City Chiefs": {"lat": 39.0489, "lon": -94.4839},
        "San Francisco 49ers": {"lat": 37.4031, "lon": -121.9698},
        "Philadelphia Eagles": {"lat": 39.9011, "lon": -75.1677},
        "Dallas Cowboys": {"lat": 32.7473, "lon": -97.0945},
        "Baltimore Ravens": {"lat": 39.2780, "lon": -76.6227},
        "Cincinnati Bengals": {"lat": 39.0954, "lon": -84.5161},
        "Miami Dolphins": {"lat": 25.9580, "lon": -80.2389}
    }
    
    if team not in stadiums:
        return jsonify({"error": "Team not found"}), 404
    
    lat, lon = stadiums[team]["lat"], stadiums[team]["lon"]
    
    try:
        # Get forecast URL from NWS
        points_url = f"https://api.weather.gov/points/{lat},{lon}"
        points_response = requests.get(points_url, headers={"User-Agent": "NFL Betting App"})
        forecast_url = points_response.json()['properties']['forecastHourly']
        
        # Get actual weather
        weather_response = requests.get(forecast_url, headers={"User-Agent": "NFL Betting App"})
        periods = weather_response.json()['properties']['periods']
        
        if periods:
            current = periods[0]
            
            # Calculate impact
            temp = current['temperature']
            wind = int(current.get('windSpeed', '0 mph').split()[0])
            precip = current.get('probabilityOfPrecipitation', {}).get('value', 0)
            
            if wind > 20:
                impact = "⚠️ HIGH WIND - Major passing/kicking impact"
            elif wind > 15:
                impact = "🌬️ Moderate wind - May affect deep passes"
            elif precip > 70:
                impact = "🌧️ Heavy rain - Slippery conditions"
            elif precip > 40:
                impact = "☔ Chance of rain - May affect grip"
            elif temp < 32:
                impact = "❄️ Freezing - Ball hardness affected"
            else:
                impact = "✅ Good weather - Minimal impact"
            
            return jsonify({
                "temperature": current['temperature'],
                "conditions": current['shortForecast'],
                "wind_speed": current['windSpeed'],
                "precipitation": precip,
                "humidity": "N/A",
                "stadium": team,
                "impact": impact
            })
    except Exception as e:
        return jsonify({
            "error": "Weather unavailable",
            "mock": True,
            "temperature": 45,
            "conditions": "Partly Cloudy",
            "wind_speed": "10 mph",
            "precipitation": 20,
            "impact": "Mock data - NWS unavailable"
        }), 200

if __name__ == '__main__':
    print("🏈 NFL BETTING API WITH ESPN DATA")
    print("📡 Using ESPN API (completely free)")
    print("🚀 Server running at http://localhost:5000")
    print("\n📊 Endpoints available:")
    print("   GET /test")
    print("   GET /team_stats?team=Buffalo%20Bills")
    print("   GET /player_stats?name=Josh%20Allen")
    print("   GET /injuries?team=Buffalo%20Bills")
    print("   GET /news?entity=Buffalo%20Bills")
    print("   GET /win_loss?team=Buffalo%20Bills")
    print("   GET /weather?team=Buffalo%20Bills")
    app.run(host='0.0.0.0', port=5000, debug=True)
